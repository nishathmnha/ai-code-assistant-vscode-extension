{
  "name": "ai-code-assistant",
  "displayName": "AI Code Assistant",
  "description": "AI Code Assistant extension",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:aiCodeAssistant.askAI",
    "onView:aiCodeAssistant.chatView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "aiCodeAssistant.askAI",
        "title": "AI Code Assistant: Ask AI"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "aiCodeAssistant",
          "title": "AI Code Assistant",
          "icon": "media/assistant.svg"
        }
      ]
    },
    "views": {
      "aiCodeAssistant": [
        {
          "type": "webview",
          "id": "aiCodeAssistant.chatView",
          "name": "Assistant"
        }
      ]
    },
    "configuration": {
      "title": "AI Code Assistant",
      "properties": {
        "aiCodeAssistant.provider": {
          "type": "string",
          "default": "openai",
          "enum": [
            "openai",
            "groq",
            "ollama",
            "anthropic",
            "google",
            "deepseek",
            "openrouter",
            "custom"
          ],
          "description": "LLM provider used by AI Code Assistant."
        },
        "aiCodeAssistant.model": {
          "type": "string",
          "default": "gpt-4o-mini",
          "description": "Model name used by the selected LLM provider."
        },
        "aiCodeAssistant.ollamaBaseUrl": {
          "type": "string",
          "default": "http://localhost:11434/v1",
          "description": "OpenAI-compatible Ollama base URL."
        },
        "aiCodeAssistant.customBaseUrl": {
          "type": "string",
          "default": "",
          "description": "Custom OpenAI-compatible provider base URL."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.120.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
